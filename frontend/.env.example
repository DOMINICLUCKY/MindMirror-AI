# Frontend Environment Variables for OAuth Integration
# Copy this file to .env.local and fill in your OAuth credentials

# Google OAuth
REACT_APP_GOOGLE_CLIENT_ID=your_google_client_id_here
REACT_APP_GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# GitHub OAuth
REACT_APP_GITHUB_CLIENT_ID=your_github_client_id_here
REACT_APP_GITHUB_CLIENT_SECRET=your_github_client_secret_here

# Apple OAuth
REACT_APP_APPLE_TEAM_ID=your_apple_team_id_here
REACT_APP_APPLE_CLIENT_ID=your_apple_client_id_here
REACT_APP_APPLE_KEY_ID=your_apple_key_id_here

# Backend API
REACT_APP_API_URL=http://localhost:5000
